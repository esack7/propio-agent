{
  "name": "@propio-ai/agent",
  "version": "1.1.1",
  "description": "Multi-provider AI agent CLI supporting Ollama, Bedrock, OpenRouter, Gemini, xAI, and Cloudflare",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "propio": "./bin/propio.cjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/esack7/propio-agent.git"
  },
  "homepage": "https://github.com/esack7/propio-agent#readme",
  "bugs": {
    "url": "https://github.com/esack7/propio-agent/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "ollama",
    "bedrock",
    "openrouter",
    "gemini",
    "xai",
    "cloudflare"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin/propio.cjs",
    "bin/propio-sandbox",
    "docker-compose.yml",
    "Dockerfile",
    "LICENSE",
    "README.md",
    "npm-shrinkwrap.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest",
    "test:watch": "NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest --watch",
    "test:openrouter": "NODE_OPTIONS=\"--experimental-vm-modules --disable-warning=ExperimentalWarning\" jest openrouter",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@propio-ai/providers": "0.1.2",
    "chalk": "5.6.2",
    "cli-highlight": "^2.1.11",
    "fast-glob": "3.3.3",
    "marked": "^18.0.4",
    "minimatch": "^10.2.5",
    "yaml": "^2.8.3",
    "yocto-spinner": "^1.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "30.3.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.2",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.6"
  }
}
